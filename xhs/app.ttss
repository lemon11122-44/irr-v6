page {
  background: #f5f5f5;
  font-size: 28rpx;
  color: #333;
  font-family: -apple-system, sans-serif;
}
.pg { padding: 20rpx; }
.ld { text-align: center; padding: 60rpx 0; color: #999; }
.emp { text-align: center; padding: 100rpx 0; }
.emp-i { font-size: 80rpx; display: block; }
.emp-t { color: #999; font-size: 28rpx; margin-top: 20rpx; display: block; }
