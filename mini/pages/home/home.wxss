page{background:#f5f7fa;font-size:28rpx;color:#000;font-family:-apple-system,sans-serif}
.pg{padding:0 24rpx;padding-top:88rpx}
.bar{display:flex;justify-content:space-between;align-items:center;padding:16rpx 0;margin-bottom:8rpx}
.bl{display:flex;align-items:center}
.lg{width:48rpx;height:48rpx;background:#1677FF;border-radius:10rpx;display:flex;align-items:center;justify-content:center;color:#fff;font-size:28rpx;font-weight:700;margin-right:12rpx}
.tt{font-size:36rpx;font-weight:700}
.br .cp{display:flex;align-items:center;background:#f0f0f0;border-radius:40rpx;padding:4rpx}
.ci{padding:8rpx 16rpx;font-size:24rpx;color:#333}
.cd{width:1rpx;height:24rpx;background:#ddd}

/* 模式切换 */
.mt{display:flex;gap:16rpx;margin-bottom:20rpx}
.mtb{flex:1;text-align:center;padding:16rpx;border-radius:12rpx;font-size:28rpx;color:#666;background:#fff;box-shadow:0 1px 4px rgba(0,0,0,.04)}
.mtb.on{background:#1677FF;color:#fff;font-weight:600}

/* 表单 */
.fm{background:#fff;border-radius:16rpx;padding:28rpx 24rpx;margin-bottom:24rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.04)}
.fi{margin-bottom:20rpx}
.fl{font-size:26rpx;color:#666;display:block;margin-bottom:8rpx;font-weight:500}
.fi input{width:100%;border:2rpx solid #eee;border-radius:12rpx;padding:20rpx;font-size:30rpx;outline:none;background:#fafafa;color:#333}
.fi input:focus{border-color:#1677FF;background:#fff}
.fi input::placeholder{color:#ccc}
.calc-btn{width:100%;padding:22rpx;background:#1677FF;color:#fff;border:none;border-radius:14rpx;font-size:32rpx;font-weight:600;margin-top:8rpx;letter-spacing:2rpx}
.calc-btn:active{background:#1366dd}

/* 利率/总额切换 */
.rtgl{display:flex;background:#f5f5f5;border-radius:10rpx;overflow:hidden;padding:4rpx}
.rti{flex:1;text-align:center;padding:14rpx 8rpx;font-size:26rpx;color:#999;border-radius:8rpx}
.rti.on{background:#1677FF;color:#fff;font-weight:600}

/* 结果 */
.rs{background:#fff;border-radius:16rpx;overflow:hidden;margin-bottom:24rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.04)}
.rt{background:#1677FF;color:#fff;font-size:28rpx;font-weight:600;padding:18rpx 24rpx;text-align:center}
.rg{padding:20rpx 24rpx}
.rg1{background:#fff}
.rg2{background:#fffbf0;border-top:1rpx solid #f5f5f5}
.rg-title{font-size:24rpx;color:#e6a23c;margin-bottom:12rpx;font-weight:600}
.ri{display:flex;justify-content:space-between;align-items:center;padding:14rpx 0;border-bottom:1rpx solid #f8f8f8}
.ri:last-child{border-bottom:none}
.rk{font-size:26rpx;color:#666}
.rv{font-size:28rpx;color:#333;font-weight:700}
.hv{color:#e53935}
.sec{margin-bottom:24rpx}
.stt{font-size:32rpx;font-weight:700;display:block;margin-bottom:14rpx}
.swp{height:200rpx;border-radius:16rpx;overflow:hidden}
.swc{height:100%;padding:28rpx;display:flex;flex-direction:column;justify-content:flex-start;padding-top:24rpx}
.swt{color:#fff;font-size:32rpx;font-weight:700;display:block}
.sws{color:rgba(255,255,255,.85);font-size:24rpx;margin-top:10rpx;display:block}
.swb{color:rgba(255,255,255,.7);font-size:22rpx;margin-top:12rpx;display:block;white-space:pre-wrap;line-height:1.6}
.bs{height:120rpx}
.kf{position:fixed;top:40%;right:30rpx;width:120rpx;height:120rpx;margin-top:-60rpx;background:#1677FF;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4rpx 16rpx rgba(22,119,255,.3);z-index:999}
.kf text{font-size:24rpx;font-weight:600;color:#fff}
.gh{transform:scale(.95)}
